# Runtime
NODE_ENV=development
PORT=4000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
MONGODB_DB_NAME=house_rent_dev

# JWT
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# App / cross-service
CLIENT_APP_URL=http://localhost:3000
DEFAULT_TRIAL_DAYS=14
COOKIE_DOMAIN=localhost

# Email (SMTP — e.g. Gmail with an App Password: myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=replace-with-your-email@gmail.com
SMTP_PASSWORD=replace-with-a-16-char-app-password
SMTP_FROM="House Rent Management <replace-with-your-email@gmail.com>"
